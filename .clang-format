# Style C++ của Deskhub — bám sát code hiện có: thụt 4 space, ngoặc mở dính dòng,
# con trỏ áp trái (uint8_t* p), namespace không thụt thêm. SortIncludes tắt vì các
# file gom include theo nhóm có comment, sắp lại sẽ phá thứ tự cố ý đó.
BasedOnStyle: Google
Standard: c++20
ColumnLimit: 100
IndentWidth: 4
TabWidth: 4
UseTab: Never
AccessModifierOffset: -4
PointerAlignment: Left
DerivePointerAlignment: false
NamespaceIndentation: None
BreakBeforeBraces: Attach
AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: false
AllowShortLoopsOnASingleLine: false
Cpp11BracedListStyle: true
SortIncludes: false
