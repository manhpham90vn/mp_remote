# =============================================================================
# Fastfile (iOS) — build ipa Release rồi đẩy lên TestFlight. Chạy từ CI
# (.github/workflows/deploy.yml) hoặc tay: cd client/ios && fastlane ios release
#
# FASTLANE LÀ NGUỒN CHUẨN của danh tính/version app:
#   - bundle id + team        : fastlane/Appfile (app_identifier, team_id)
#   - version hiển thị (x.y.z): file VERSION ở gốc repo (chung với Android)
#   - build number            : env BUILD_NUMBER (CI truyền github.run_number)
# Các giá trị này được bơm vào xcodebuild qua xcargs, ĐÈ lên giá trị trong
# Deskhub.xcodeproj — pbxproj chỉ còn là fallback khi build tay bằng Xcode.
#
# Đăng nhập bằng App Store Connect API key (không dùng mật khẩu Apple ID):
#   ASC_KEY_ID      — Key ID của API key (App Store Connect > Users > Keys)
#   ASC_ISSUER_ID   — Issuer ID cùng trang đó
#   ASC_KEY_CONTENT — nội dung file .p8, mã hoá base64 một dòng
# Ký app: cloud signing tự động — xcodebuild tự tạo/tải cert + profile qua API
# key (-allowProvisioningUpdates), không phải nhét cert thủ công vào runner.
# =============================================================================
default_platform(:ios)

APP_IDENTIFIER = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)
TEAM_ID = CredentialsManager::AppfileConfig.try_fetch_value(:team_id)
APP_VERSION = File.read(File.expand_path("../../../VERSION", __dir__)).strip

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_content: ENV.fetch("ASC_KEY_CONTENT"),
    is_key_content_base64: true
  )
end

platform :ios do
  desc "Build ipa Release (cloud signing) và upload TestFlight"
  lane :release do
    api_key = asc_api_key

    # xcodebuild nhận API key qua file .p8 (-authenticationKey*) — ghi tạm ra
    # cạnh Fastfile rồi xoá sau khi build xong.
    key_path = File.absolute_path("asc_authkey.p8")
    File.binwrite(key_path, Base64.decode64(ENV.fetch("ASC_KEY_CONTENT")))
    auth = "-allowProvisioningUpdates " \
           "-authenticationKeyPath #{key_path} " \
           "-authenticationKeyID #{ENV.fetch('ASC_KEY_ID')} " \
           "-authenticationKeyIssuerID #{ENV.fetch('ASC_ISSUER_ID')}"

    build_number = ENV["BUILD_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")
    identity = "PRODUCT_BUNDLE_IDENTIFIER=#{APP_IDENTIFIER} " \
               "DEVELOPMENT_TEAM=#{TEAM_ID} " \
               "MARKETING_VERSION=#{APP_VERSION} " \
               "CURRENT_PROJECT_VERSION=#{build_number}"

    begin
      build_app(
        project: "Deskhub.xcodeproj",
        scheme: "app",
        configuration: "Release",
        export_method: "app-store",
        output_directory: "build",
        xcargs: "#{auth} #{identity}",
        export_xcargs: auth
      )
    ensure
      File.delete(key_path) if File.exist?(key_path)
    end

    upload_to_testflight(api_key: api_key, skip_waiting_for_build_processing: true)
  end

  # Store listing quản bằng file txt trong fastlane/metadata/<locale>/ (deliver):
  #   name/subtitle/description/keywords/release_notes/*_url.txt + copyright,
  #   primary_category, secondary_category ở gốc metadata/. Sửa chữ = sửa file
  #   txt rồi chạy lane này (CI: workflow metadata.yml) — không cần build lại app.
  desc "Đẩy store listing (fastlane/metadata) lên App Store Connect"
  lane :metadata do
    deliver(
      api_key: asc_api_key,
      app_version: APP_VERSION,
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true, # không dừng chờ duyệt HTML preview — CI không có ai bấm
      precheck_include_in_app_purchases: false
    )
  end
end
